# ─── Backend Environment Variables ─────────────────────────────────────────

# Directory where uploaded files + session data are stored
# Defaults to OS temp dir if not set
UPLOAD_DIR=/tmp/expense_validator

# Google Sheets export — path to your service account JSON key file
# Download from Google Cloud Console → IAM → Service Accounts → Keys
# Required only if using the /export/sheets endpoint
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Tesseract binary path (Windows only — Linux/Mac usually auto-detected)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Poppler path for pdf2image (Windows only)
# POPPLER_PATH=C:/poppler/Library/bin
